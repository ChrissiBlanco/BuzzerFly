generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Room {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String?
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  rounds    Round[]

  @@index([creatorId])
}

model Round {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(0)
  questions Question[]

  @@index([roomId])
}

model Question {
  id       String @id @default(uuid())
  roundId  String
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  order    Int    @default(0)
  text     String

  @@index([roundId, order])
}
