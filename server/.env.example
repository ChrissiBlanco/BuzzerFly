# Neon: use the “ pooled ” URL for DATABASE_URL (-pooler in host) and the “ direct ” URL for DIRECT_URL
# (no -pooler). For local Postgres or Neon direct-only, set both to the same string.
# Add sslmode=require (Neon) and connect_timeout=15 to avoid wake-from-sleep timeouts.
# Pooled Prisma URL often includes: ?sslmode=require&connect_timeout=15&pgbouncer=true
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
PORT=3001
# Fly.io: leave PORT unset or 8080 to match fly.toml internal_port; do not set PORT=3001 as a Fly secret.
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173
